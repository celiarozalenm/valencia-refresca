---
import Logo from './Logo.astro';
---

<footer class="border-t border-(--color-ink)/10">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-12 sm:grid-cols-2 md:grid-cols-4 md:px-10">
    <div>
      <a href="/" class="flex items-center gap-2.5 text-(--color-ink)">
        <Logo size={32} />
        <span class="font-display text-lg leading-none font-semibold">
          València<br /><span class="font-medium">Refresca</span>
        </span>
      </a>
      <p class="mt-4 text-sm font-medium text-(--color-ink-soft)">Agua. Sombra. Respiramos.</p>
      <div class="mt-3 h-[3px] w-12 bg-(--color-calor)"></div>
    </div>

    <div class="text-sm text-(--color-ink-soft)">
      <p class="max-w-[18ch]">Una iniciativa cívica para una València más habitable.</p>
    </div>

    <ul class="space-y-2 text-sm text-(--color-ink-soft)">
      <li><a href="#" class="transition hover:text-(--color-ink)">Privacidad</a></li>
      <li><a href="mailto:hola@valenciarefresca.com" class="transition hover:text-(--color-ink)">Contacto</a></li>
      <li><a href="#colabora" class="transition hover:text-(--color-ink)">Colaborar</a></li>
    </ul>

    <div>
      <p class="text-sm font-semibold text-(--color-ink)">Síguenos</p>
      <div class="mt-3 flex gap-3">
        <a href="#" aria-label="Twitter" class="flex h-9 w-9 items-center justify-center rounded-full bg-(--color-agua) text-white transition hover:bg-(--color-ink)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 5.8a8.5 8.5 0 0 1-2.4.7 4.2 4.2 0 0 0 1.8-2.3 8.4 8.4 0 0 1-2.6 1 4.2 4.2 0 0 0-7.3 3.8 12 12 0 0 1-8.7-4.4 4.2 4.2 0 0 0 1.3 5.6 4.2 4.2 0 0 1-1.9-.5v.1A4.2 4.2 0 0 0 5.5 14a4.2 4.2 0 0 1-1.9.1 4.2 4.2 0 0 0 3.9 2.9A8.5 8.5 0 0 1 2 18.8 12 12 0 0 0 8.5 21c7.8 0 12-6.5 12-12v-.5A8.5 8.5 0 0 0 22 5.8z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-full bg-(--color-agua) text-white transition hover:bg-(--color-ink)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
        <a href="#" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-full bg-(--color-agua) text-white transition hover:bg-(--color-ink)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 22v-9h3l.5-3.5h-3.5V7c0-1 .3-1.7 1.8-1.7H17V2.2C16.4 2.1 15.3 2 14 2c-3 0-5 1.8-5 5v3H6v3.5h3V22z"/></svg>
        </a>
      </div>
      <p class="mt-4 text-sm text-(--color-ink-soft)">
        Hecho en València con <span class="text-(--color-agua)">♥</span>
      </p>
    </div>
  </div>
</footer>
