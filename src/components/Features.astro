---
const features = [
  {
    icon: 'fuente',
    title: 'Fuentes',
    desc: '832 puntos de agua potable cartografiados.',
    link: '#mapa',
    colorVar: '--color-agua',
  },
  {
    icon: 'urinario',
    title: 'Urinarios',
    desc: '230 urinarios públicos. 1 de cada 4 manzanas, a más de 5 min.',
    link: '#mapa',
    colorVar: '--color-calor',
  },
  {
    icon: 'sombra',
    title: 'Sombra',
    desc: '186.820 árboles del padrón de arbolado.',
    link: '#mapa',
    colorVar: '--color-sombra',
  },
];
---

<section id="capas" class="border-t border-(--color-ink)/8">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-3 md:px-10 md:py-20">
    {features.map((f) => (
      <div class="flex flex-col items-center text-center">
        <div
          class="flex h-16 w-16 items-center justify-center rounded-full"
          style={`background: var(${f.colorVar});`}
        >
          {f.icon === 'fuente' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M12 2 C 16 9, 20 13, 20 17 A 8 8 0 0 1 4 17 C 4 13, 8 9, 12 2 Z" />
            </svg>
          )}
          {f.icon === 'urinario' && (
            <svg width="26" height="26" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <rect x="6" y="3" width="12" height="14" rx="2" />
              <rect x="10" y="17" width="4" height="4" />
              <circle cx="12" cy="10" r="2.4" fill="currentColor" style="color: var(--color-calor)" />
            </svg>
          )}
          {f.icon === 'sombra' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M12 2 C 7 5, 4 9, 4 13 A 8 8 0 0 0 11 21 L 11 22 L 13 22 L 13 21 A 8 8 0 0 0 20 13 C 20 9, 17 5, 12 2 Z" />
            </svg>
          )}
        </div>

        <h3 class="mt-6 font-display text-2xl font-semibold text-(--color-ink)">{f.title}</h3>
        <p class="mt-2 max-w-[16rem] text-sm text-(--color-ink-soft)">{f.desc}</p>

        <a
          href={f.link}
          class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium transition hover:opacity-70"
          style={`color: var(${f.colorVar});`}
        >
          Ver en el mapa
          <span aria-hidden="true">→</span>
        </a>
      </div>
    ))}
  </div>
</section>
