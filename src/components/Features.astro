---
import { t, type Lang, mapaHref } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const f = t(lang).features;
const mapaUrl = mapaHref(lang);

const features = [
  {
    icon: 'fuente',
    title: f.fuentes.title,
    desc: f.fuentes.desc,
    colorVar: '--color-agua',
    deepVar: '--color-agua-deep',
  },
  {
    icon: 'urinario',
    title: f.urinarios.title,
    desc: f.urinarios.desc,
    colorVar: '--color-calor',
    deepVar: '--color-calor-deep',
  },
  {
    icon: 'sombra',
    title: f.sombra.title,
    desc: f.sombra.desc,
    colorVar: '--color-sombra',
    deepVar: '--color-sombra-deep',
  },
];
---

<section id="capas" class="border-y border-(--color-ink)/8 bg-(--color-bone-soft)">
  <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-3 md:px-10 md:py-20">
    {features.map((feat) => (
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        {feat.icon === 'fuente' && (
          <img src="/icons/gota.svg" alt="" class="h-16 w-16" aria-hidden="true" />
        )}
        {feat.icon === 'urinario' && (
          <img src="/icons/urinario.svg" alt="" class="h-16 w-16" aria-hidden="true" />
        )}
        {feat.icon === 'sombra' && (
          <img src="/icons/arbol.svg" alt="" class="h-16 w-16" aria-hidden="true" />
        )}

        <h3 class="mt-5 font-display text-2xl font-semibold text-(--color-ink)">{feat.title}</h3>
        <p class="mt-1.5 max-w-[18rem] text-sm text-(--color-ink-soft)">{feat.desc}</p>

        <a
          href={mapaUrl}
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium transition hover:opacity-70"
          style={`color: var(${feat.deepVar});`}
        >
          {f.saberMas}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    ))}
  </div>
</section>
