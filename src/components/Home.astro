---
import Hero from './Hero.astro';
import Stats from './Stats.astro';
import HowItWorks from './HowItWorks.astro';
import Banner from './Banner.astro';
import CollaborateBox from './CollaborateBox.astro';
import FAQ from './FAQ.astro';
import Findings from './Findings.astro';
import MapLazy from './MapLazy.tsx';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const m = t(lang).map;
---

<Hero lang={lang} />
<Stats lang={lang} />
<HowItWorks lang={lang} />
<Banner lang={lang} />

<section id="mapa" class="border-t border-(--color-ink)/8">
  <div class="mx-auto max-w-7xl px-6 py-20 md:px-10">
    <div class="mb-10 max-w-3xl">
      <p class="font-sans text-sm font-medium tracking-[0.18em] uppercase text-(--color-agua-deep)">{m.eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl leading-tight text-(--color-ink) md:text-5xl">
        {m.heading}
      </h2>
      <p class="mt-4 max-w-2xl text-(--color-ink-soft) md:text-lg">
        {m.description}
      </p>
    </div>

    <MapLazy client:only="react" lang={lang} />
  </div>
</section>

<Findings lang={lang} />
<CollaborateBox lang={lang} />
<FAQ lang={lang} />
