---
import Hero from './Hero.astro';
import Features from './Features.astro';
import HowItWorks from './HowItWorks.astro';
import Banner from './Banner.astro';
import MapFeatures from './MapFeatures.astro';
import CollaborateBox from './CollaborateBox.astro';
import FAQ from './FAQ.astro';
import Findings from './Findings.astro';
import ProjectInfo from './ProjectInfo.astro';
import { type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
---

<Hero lang={lang} />
<Features lang={lang} />
<HowItWorks lang={lang} />
<Banner lang={lang} />
<MapFeatures lang={lang} />
<Findings lang={lang} />
<CollaborateBox lang={lang} />
<FAQ lang={lang} />
<ProjectInfo lang={lang} />
