---
// "Información útil para vivir el verano mejor" — banner con escena de Ciudad de las Artes
// hecho íntegramente en CSS/SVG.
---

<section class="mx-auto max-w-6xl px-6 md:px-10">
  <div class="relative overflow-hidden rounded-2xl bg-[#5a8db4]">
    <!-- Cielo + sol -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, #6ba0c8 0%, #9cc6e0 55%, #b8d8e8 100%);"
      aria-hidden="true"
    ></div>
    <div
      class="absolute top-10 right-1/3 h-20 w-20 rounded-full opacity-70"
      style="background: radial-gradient(circle, #fff4d6 0%, #ffe8b0 60%, transparent 100%);"
      aria-hidden="true"
    ></div>

    <!-- Escena: Ciudad de las Artes (siluetas SVG) -->
    <svg viewBox="0 0 800 360" class="absolute inset-x-0 bottom-0 h-full w-full" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <!-- Nubes -->
      <g fill="#ffffff" opacity="0.7">
        <ellipse cx="160" cy="60" rx="48" ry="10" />
        <ellipse cx="200" cy="68" rx="60" ry="9" />
        <ellipse cx="620" cy="50" rx="55" ry="8" />
      </g>

      <!-- Agua reflejos -->
      <rect x="0" y="250" width="800" height="110" fill="#3a6f93" />
      <g stroke="#5e9bc2" stroke-width="2" opacity="0.4">
        <line x1="0" y1="280" x2="800" y2="280" />
        <line x1="0" y1="305" x2="800" y2="305" />
        <line x1="0" y1="330" x2="800" y2="330" />
      </g>

      <!-- Hemisféric (cúpula de ojo) -->
      <ellipse cx="180" cy="240" rx="120" ry="40" fill="#dbe6ee" />
      <ellipse cx="180" cy="230" rx="115" ry="30" fill="#e7eff5" />
      <path d="M60 240 Q 180 145 300 240 Z" fill="#ffffff" opacity="0.85" />
      <ellipse cx="180" cy="220" rx="40" ry="14" fill="#9cb6c8" opacity="0.55" />

      <!-- Palmeras -->
      <g>
        <rect x="40" y="160" width="6" height="90" fill="#3d2916" />
        <g fill="#1a5638">
          <path d="M43 160 Q 20 145 5 155 Q 30 158 43 170 Z" />
          <path d="M43 160 Q 70 145 90 155 Q 60 158 43 170 Z" />
          <path d="M43 160 Q 35 130 25 120 Q 38 145 46 165 Z" />
          <path d="M43 160 Q 55 130 70 125 Q 52 148 43 165 Z" />
        </g>
      </g>
      <g>
        <rect x="730" y="180" width="6" height="70" fill="#3d2916" />
        <g fill="#1a5638">
          <path d="M733 180 Q 715 165 700 175 Q 720 178 733 188 Z" />
          <path d="M733 180 Q 755 165 770 175 Q 745 178 733 188 Z" />
          <path d="M733 180 Q 728 150 720 142 Q 730 165 736 182 Z" />
        </g>
      </g>

      <!-- Umbracle (estructura blanca) -->
      <g stroke="#ffffff" stroke-width="3" fill="none">
        <path d="M340 240 L 340 160 Q 460 110 580 160 L 580 240" />
        <path d="M360 240 L 360 165 Q 460 120 560 165 L 560 240" />
        <path d="M380 240 L 380 172 Q 460 135 540 172 L 540 240" />
        <line x1="340" y1="160" x2="580" y2="160" />
        <line x1="360" y1="170" x2="560" y2="170" />
      </g>
      <rect x="335" y="240" width="250" height="10" fill="#e9e3d4" />

      <!-- Museo de las Ciencias (Calatrava — esqueleto) -->
      <g fill="#f4f1e8">
        <path d="M620 250 Q 700 160 780 250 Z" />
      </g>
      <g stroke="#d4cfbc" stroke-width="1.5" fill="none">
        <path d="M620 250 Q 700 160 780 250" />
        <path d="M630 250 Q 705 175 770 250" />
        <path d="M640 250 Q 710 190 760 250" />
        <line x1="650" y1="250" x2="700" y2="170" />
        <line x1="670" y1="250" x2="710" y2="180" />
        <line x1="690" y1="250" x2="720" y2="195" />
      </g>
    </svg>

    <!-- Texto encima -->
    <div class="relative z-10 max-w-md p-8 sm:p-10 md:p-12">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white/85">València arde</p>
      <h2 class="mt-4 font-display text-3xl leading-tight font-medium text-white sm:text-4xl md:text-5xl">
        Dónde la ciudad<br />se cuida —<br />y dónde no.
      </h2>
      <div class="mt-5 h-[3px] w-16 bg-(--color-calor)"></div>
    </div>

    <!-- Altura mínima del bloque -->
    <div class="relative h-[320px] w-full sm:h-[360px] md:h-[400px]"></div>
  </div>
</section>
