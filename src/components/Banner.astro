---
// "Información útil para vivir el verano mejor": banner editorial.
// Ilustración de fondo pendiente — placeholder gris hasta que llegue la imagen final.
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const s = t(lang).banner;
---

<section class="mx-auto max-w-6xl px-6 md:px-10">
  <div class="relative overflow-hidden rounded-2xl bg-(--color-agua-soft)/60 ring-1 ring-(--color-ink)/8">
    <!-- Placeholder de la ilustración -->
    <div
      class="absolute inset-0 flex items-center justify-end p-8 md:p-12"
      aria-hidden="true"
    >
      <div class="h-full w-full max-w-md rounded-2xl border-2 border-dashed border-(--color-ink)/15 bg-white/40 flex items-center justify-center">
        <span class="font-mono text-[11px] tracking-wider uppercase text-(--color-ink)/40">
          Ilustración pendiente
        </span>
      </div>
    </div>

    <!-- Texto encima -->
    <div class="relative z-10 max-w-md p-8 sm:p-10 md:p-12">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-(--color-agua-deep)">{s.eyebrow}</p>
      <h2 class="mt-4 font-display text-3xl leading-tight font-medium text-(--color-ink) sm:text-4xl md:text-5xl">
        {s.titleLine1}<br />{s.titleLine2}<br />{s.titleLine3}
      </h2>
      <div class="mt-5 h-[3px] w-16 bg-(--color-calor)"></div>
    </div>

    <!-- Altura mínima del bloque -->
    <div class="relative h-[320px] w-full sm:h-[360px] md:h-[400px]"></div>
  </div>
</section>
