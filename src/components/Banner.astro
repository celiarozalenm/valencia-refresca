---
// "Información útil para vivir el verano mejor": banner editorial.
// Imagen de fondo pendiente — placeholder de momento.
// Cuando llegue la imagen final, sustituir el <div placeholder> por:
//   <img src="/banner.jpg" alt="" class="absolute inset-0 h-full w-full object-cover" />
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const s = t(lang).banner;
---

<section class="mx-auto max-w-6xl px-6 md:px-10">
  <div class="relative isolate overflow-hidden rounded-2xl ring-1 ring-(--color-ink)/8">
    <!-- Placeholder de la imagen de fondo (sustituir por <img> cuando llegue la final) -->
    <div
      class="absolute inset-0 flex items-center justify-center bg-(--color-agua) text-white/50"
      aria-hidden="true"
    >
      <span class="font-mono text-xs tracking-wider uppercase">Imagen pendiente</span>
    </div>

    <!-- Degradado para legibilidad del texto (izquierda) -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-(--color-ink)/65 via-(--color-ink)/25 to-transparent"
      aria-hidden="true"
    ></div>

    <!-- Texto encima -->
    <div class="relative z-10 max-w-md p-8 sm:p-10 md:p-12">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white/85">{s.eyebrow}</p>
      <h2 class="mt-4 font-display text-2xl leading-tight font-medium text-white sm:text-3xl md:text-[2rem]">
        {s.titleLine1}<br />{s.titleLine2}<br />{s.titleLine3}
      </h2>
      <div class="mt-5 h-[3px] w-16 bg-(--color-calor)"></div>
    </div>

    <!-- Altura mínima del bloque -->
    <div class="relative h-[200px] w-full sm:h-[230px] md:h-[260px]"></div>
  </div>
</section>
