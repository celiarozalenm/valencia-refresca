---
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const tr = t(lang).howItWorks;

const palettes = [
  { bgVar: '--color-agua-soft', fgVar: '--color-agua' },
  { bgVar: '--color-calor-soft', fgVar: '--color-calor' },
  { bgVar: '--color-sombra-soft', fgVar: '--color-sombra' },
];

const steps = tr.steps.map((step, i) => ({
  n: i + 1,
  title: step.title,
  desc: step.desc,
  bgVar: palettes[i].bgVar,
  fgVar: palettes[i].fgVar,
}));
---

<section class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-24">
  <h2 class="text-center font-display text-3xl text-(--color-ink) md:text-4xl">{tr.heading}</h2>

  <div class="mt-12 grid items-start gap-12 md:grid-cols-[1fr_auto_1fr_auto_1fr] md:gap-6">
    {steps.map((step, i) => (
      <>
        <div class="flex flex-col items-center text-center">
          <div
            class="relative flex aspect-square w-full max-w-[220px] items-center justify-center overflow-hidden rounded-2xl"
            style={`background: var(${step.bgVar});`}
            aria-hidden="true"
          >
            {step.n === 1 && (
              <svg viewBox="0 0 200 200" class="absolute inset-0 h-full w-full">
                {/* Plano simplificado */}
                <g stroke="#ffffff" stroke-width="3" stroke-linecap="round" fill="none">
                  <path d="M-10 60 Q 80 50 120 80 T 220 70" />
                  <path d="M-10 140 Q 80 130 130 150 T 220 145" />
                  <path d="M50 -10 Q 60 80 80 130 T 100 220" />
                  <path d="M150 -10 Q 160 80 175 130 T 165 220" />
                </g>
                {/* Tarjeta de capas, top-left */}
                <g transform="translate(20 20)">
                  <rect x="0" y="0" width="86" height="96" rx="10" fill="#ffffff" />
                  <rect x="8" y="10" width="40" height="6" rx="3" fill="#1f2937" />
                  <g transform="translate(8 26)">
                    <rect x="0" y="0" width="14" height="14" rx="3" fill="#3b82f6" />
                    <path d="M3 7 l3 3 5-6" stroke="#ffffff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    <rect x="20" y="3" width="36" height="6" rx="3" fill="#475569" />
                  </g>
                  <g transform="translate(8 46)">
                    <rect x="0" y="0" width="14" height="14" rx="3" fill="#f97316" />
                    <path d="M3 7 l3 3 5-6" stroke="#ffffff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    <rect x="20" y="3" width="30" height="6" rx="3" fill="#475569" />
                  </g>
                  <g transform="translate(8 66)">
                    <rect x="0" y="0" width="14" height="14" rx="3" fill="#22c55e" />
                    <path d="M3 7 l3 3 5-6" stroke="#ffffff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    <rect x="20" y="3" width="42" height="6" rx="3" fill="#475569" />
                  </g>
                </g>
                {/* Pins puntuales */}
                <g>
                  <circle cx="135" cy="60" r="6" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                  <circle cx="160" cy="105" r="7" fill="#f97316" stroke="#ffffff" stroke-width="2" />
                  <circle cx="125" cy="155" r="6" fill="#22c55e" stroke="#ffffff" stroke-width="2" />
                  <circle cx="170" cy="165" r="6" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                </g>
              </svg>
            )}

            {step.n === 2 && (
              <svg viewBox="0 0 200 200" class="absolute inset-0 h-full w-full">
                {/* Plano de fondo */}
                <g stroke="#ffffff" stroke-width="3" stroke-linecap="round" fill="none">
                  <path d="M-10 80 Q 100 60 220 100" />
                  <path d="M30 -10 Q 60 100 110 220" />
                  <path d="M160 -10 Q 175 100 150 220" />
                </g>
                {/* Polígono de barrio tintado (vulnerabilidad) */}
                <path
                  d="M40 50 L 145 35 L 165 95 L 150 155 L 75 170 L 35 130 Z"
                  fill="#f97316"
                  fill-opacity="0.35"
                  stroke="#f97316"
                  stroke-width="2"
                />
                {/* Pins dentro del barrio */}
                <g>
                  <circle cx="70" cy="80" r="6" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                  <circle cx="115" cy="70" r="6" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                  <circle cx="100" cy="115" r="7" fill="#f97316" stroke="#ffffff" stroke-width="2" />
                  <circle cx="140" cy="125" r="6" fill="#22c55e" stroke="#ffffff" stroke-width="2" />
                  <circle cx="80" cy="140" r="6" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                </g>
                {/* Etiqueta */}
                <g transform="translate(110 30)">
                  <rect x="0" y="0" width="72" height="22" rx="11" fill="#1f2937" />
                  <text x="36" y="14" text-anchor="middle" fill="#ffffff" font-family="Inter, sans-serif" font-size="9" font-weight="600">VUL · ALTA</text>
                </g>
              </svg>
            )}

            {step.n === 3 && (
              <svg viewBox="0 0 200 200" class="absolute inset-0 h-full w-full">
                {/* Plano */}
                <g stroke="#ffffff" stroke-width="3" stroke-linecap="round" fill="none">
                  <path d="M-10 60 Q 100 50 220 80" />
                  <path d="M-10 140 Q 100 130 220 150" />
                  <path d="M40 -10 L 80 220" />
                  <path d="M140 -10 L 120 220" />
                </g>
                {/* Halo de "service desert" */}
                <circle cx="100" cy="100" r="55" fill="#1f2937" fill-opacity="0.08" />
                <circle cx="100" cy="100" r="55" fill="none" stroke="#1f2937" stroke-width="2" stroke-dasharray="4 4" opacity="0.55" />
                {/* Pin destacado + texto */}
                <circle cx="100" cy="100" r="14" fill="#22c55e" stroke="#ffffff" stroke-width="3" />
                <path d="M93 100 l5 5 9-10" stroke="#ffffff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                {/* Otros pins fuera */}
                <g opacity="0.55">
                  <circle cx="35" cy="40" r="5" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                  <circle cx="170" cy="45" r="5" fill="#f97316" stroke="#ffffff" stroke-width="2" />
                  <circle cx="170" cy="170" r="5" fill="#3b82f6" stroke="#ffffff" stroke-width="2" />
                  <circle cx="30" cy="165" r="5" fill="#22c55e" stroke="#ffffff" stroke-width="2" />
                </g>
                {/* Etiqueta superior */}
                <g transform="translate(20 18)">
                  <rect x="0" y="0" width="84" height="22" rx="11" fill="#ffffff" />
                  <circle cx="13" cy="11" r="4" fill="#22c55e" />
                  <text x="22" y="14" fill="#1f2937" font-family="Inter, sans-serif" font-size="9" font-weight="600">A 120 m · OK</text>
                </g>
              </svg>
            )}
          </div>

          <div class="mt-5 flex items-center gap-2">
            <span
              class="flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold text-white"
              style={`background: var(${step.fgVar});`}
            >{step.n}</span>
            <h3 class="font-display text-xl font-semibold text-(--color-ink)">{step.title}</h3>
          </div>
          <p class="mt-2 max-w-[18rem] text-sm text-(--color-ink-soft)">{step.desc}</p>
        </div>

        {i < steps.length - 1 && (
          <div class="hidden items-center justify-center pt-[100px] text-(--color-ink-soft) md:flex" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
</section>
