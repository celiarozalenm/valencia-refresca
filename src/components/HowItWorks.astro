---
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const tr = t(lang).howItWorks;

const palettes = [
  { bgVar: '--color-agua-soft', fgVar: '--color-agua' },
  { bgVar: '--color-calor-soft', fgVar: '--color-calor' },
  { bgVar: '--color-sombra-soft', fgVar: '--color-sombra' },
];

const steps = tr.steps.map((step, i) => ({
  n: i + 1,
  title: step.title,
  desc: step.desc,
  bgVar: palettes[i].bgVar,
  fgVar: palettes[i].fgVar,
}));
---

<section class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-24">
  <h2 class="text-center font-display text-3xl text-(--color-ink) md:text-4xl">{tr.heading}</h2>

  <div class="mt-12 grid items-start gap-12 md:grid-cols-[1fr_auto_1fr_auto_1fr] md:gap-6">
    {steps.map((step, i) => (
      <>
        <div class="flex flex-col items-center text-center">
          <div
            class="relative aspect-[5/4] w-full max-w-[220px] overflow-hidden rounded-2xl"
            style={step.n === 1 ? '' : `background: var(${step.bgVar});`}
            aria-hidden="true"
          >
            {step.n === 1 && (
              <img src="/illustrations/illus-1.svg" alt="" class="h-full w-full scale-[1.18] object-cover" />
            )}
            {step.n === 2 && (
              <img src="/illustrations/illus-2.svg" alt="" class="h-full w-full scale-[1.18] object-cover" />
            )}
            {step.n === 3 && (
              <img src="/illustrations/illus-3.svg" alt="" class="h-full w-full scale-[1.18] object-cover" />
            )}
          </div>

          <div class="mt-5 flex items-center gap-2">
            <span
              class="flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold text-white"
              style={`background: var(${step.fgVar});`}
            >{step.n}</span>
            <h3 class="font-display text-xl font-semibold text-(--color-ink)">{step.title}</h3>
          </div>
          <p class="mt-2 max-w-[18rem] text-sm text-(--color-ink-soft)">{step.desc}</p>
        </div>

        {i < steps.length - 1 && (
          <div class="hidden items-center justify-center pt-[100px] text-(--color-ink-soft) md:flex" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
</section>
