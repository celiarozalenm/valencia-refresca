---
const steps = [
  {
    n: 1,
    title: 'Carga el mapa',
    desc: 'Las 832 fuentes, 230 urinarios y la capa de arbolado, en una sola vista.',
  },
  {
    n: 2,
    title: 'Cruza las capas',
    desc: 'Superpón la vulnerabilidad demográfica del padrón 2021 con los servicios de alivio térmico.',
  },
  {
    n: 3,
    title: 'Lee la ciudad',
    desc: 'Descubre dónde València se cuida — y dónde quedan zonas sin agua, sin sombra y sin urinarios.',
  },
];
---

<section class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-24">
  <h2 class="text-center font-display text-3xl text-(--color-ink) md:text-4xl">Cómo se lee</h2>

  <div class="mt-12 grid items-start gap-12 md:grid-cols-[1fr_auto_1fr_auto_1fr] md:gap-6">
    {steps.map((step, i) => (
      <>
        <div class="flex flex-col items-center text-center">
          <div class="flex aspect-square w-full max-w-[220px] items-center justify-center rounded-2xl bg-(--color-agua-soft) text-xs font-medium tracking-wide text-(--color-agua)">
            Ilustración {step.n}
          </div>

          <div class="mt-5 flex items-center gap-2">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-(--color-agua) text-xs font-semibold text-white">{step.n}</span>
            <h3 class="font-display text-xl font-semibold text-(--color-ink)">{step.title}</h3>
          </div>
          <p class="mt-2 max-w-[18rem] text-sm text-(--color-ink-soft)">{step.desc}</p>
        </div>

        {i < steps.length - 1 && (
          <div class="hidden items-center justify-center text-(--color-agua) md:flex" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
</section>
