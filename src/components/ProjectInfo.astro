---
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const a = t(lang).about;
---

<section id="acerca" class="border-t border-(--color-ink)/8 bg-(--color-bone-soft)">
  <div class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-24">
    <div class="max-w-3xl">
      <p class="font-sans text-sm font-medium tracking-[0.18em] uppercase text-(--color-agua-deep)">
        {a.eyebrow}
      </p>
      <h2 class="mt-3 font-display text-3xl leading-tight text-(--color-ink) md:text-4xl">
        {a.title}
      </h2>
      <p class="mt-4 max-w-2xl text-(--color-ink-soft) md:text-lg">{a.lede}</p>
    </div>

    <div class="mt-12 grid gap-10 md:grid-cols-2">
      <!-- Stack -->
      <div class="rounded-2xl bg-white p-6 ring-1 ring-(--color-ink)/8 md:p-8">
        <p class="font-display text-lg font-semibold text-(--color-ink)">{a.stackTitle}</p>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {a.stack.map((s) => (
            <li class="rounded-xl bg-(--color-bone-soft) px-3 py-3">
              <p class="font-display text-sm font-semibold text-(--color-ink)">{s.name}</p>
              <p class="mt-0.5 text-xs leading-relaxed text-(--color-ink-soft)">{s.desc}</p>
            </li>
          ))}
        </ul>

        <p class="mt-8 font-display text-base font-semibold text-(--color-ink)">{a.reproTitle}</p>
        <p class="mt-1.5 text-sm leading-relaxed text-(--color-ink-soft)">{a.reproBody}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://github.com/celiarozalenm/valencia-refresca"
            class="inline-flex items-center gap-2 rounded-full bg-(--color-ink) px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-(--color-agua-deep)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.16c-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.92 10.92 0 0 1 5.74 0c2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.69.41.36.78 1.06.78 2.15v3.18c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
            </svg>
            {a.ctaRepo}
          </a>
          <a
            href="https://valencia.opendatasoft.com"
            class="inline-flex items-center gap-2 rounded-full border border-(--color-ink) px-5 py-2.5 text-sm font-semibold text-(--color-ink) transition hover:bg-(--color-ink) hover:text-white"
          >
            {a.ctaPortal}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Datasets -->
      <div class="rounded-2xl bg-white p-6 ring-1 ring-(--color-ink)/8 md:p-8">
        <p class="font-display text-lg font-semibold text-(--color-ink)">{a.datasetsTitle}</p>
        <p class="mt-1 text-sm text-(--color-ink-soft)">{a.datasetsCaption}</p>

        <ul class="mt-5 divide-y divide-(--color-ink)/8">
          {a.datasets.map((d) => (
            <li class="flex items-center justify-between gap-3 py-3">
              <a
                href={d.url}
                target="_blank"
                rel="noopener"
                class="flex-1 min-w-0 text-sm font-medium text-(--color-ink) transition hover:text-(--color-agua-deep)"
              >
                <span class="block truncate">{d.label}</span>
                <span class="mt-0.5 flex items-center gap-1 text-[11px] text-(--color-ink-soft)">
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-(--color-agua-deep)" aria-hidden></span>
                  valencia.opendatasoft.com
                </span>
              </a>
              <span class="shrink-0 rounded-full bg-(--color-bone-soft) px-2.5 py-1 font-display text-xs font-semibold text-(--color-ink)">
                {d.count}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
