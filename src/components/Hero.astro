---
import PhoneMockup from './PhoneMockup.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const s = t(lang).hero;
---

<section id="inicio" class="relative isolate overflow-hidden">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 pt-4 pb-20 md:grid-cols-[3fr_2fr] md:gap-6 md:pr-10 md:pl-16 md:pt-8 md:pb-28 lg:pl-24">
    <div class="flex flex-col gap-8">
      <p class="font-sans text-sm font-semibold tracking-[0.18em] uppercase text-(--color-agua-deep)">
        {s.eyebrow}
      </p>

      <h1 class="font-display text-5xl leading-[0.95] font-medium tracking-tight text-(--color-ink) sm:text-6xl md:text-[5.5rem]">
        {s.titleLine1}<br />{s.titleLine2}
      </h1>

      <p class="font-display max-w-lg text-2xl leading-tight text-(--color-ink) sm:text-3xl md:text-4xl">
        {s.claimPre} <span class="text-(--color-calor-deep) font-medium">{s.claimHighlight}</span> {s.claimPost}
      </p>

      <div class="h-[3px] w-16 bg-(--color-calor)" aria-hidden="true"></div>

      <p class="max-w-md text-base text-(--color-ink-soft)">
        {s.lead} <strong class="font-medium text-(--color-ink)">{s.leadStrong}</strong>.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <a
          href="#mapa"
          class="inline-flex items-center gap-2 rounded-full bg-(--color-ink) px-6 py-3 text-sm font-medium text-white transition hover:bg-(--color-agua-deep)"
        >
          {s.ctaPrimary}
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#faq"
          class="inline-flex items-center gap-2 rounded-full border border-(--color-ink) px-6 py-3 text-sm font-medium text-(--color-ink) transition hover:bg-(--color-ink) hover:text-white"
        >
          {s.ctaSecondary}
        </a>
      </div>
    </div>

    <div class="flex justify-center md:justify-start">
      <div class="relative">
        <!-- Halo radial detrás del móvil: blob azul + blob naranja, muy difusos, sin bordes visibles -->
        <div
          class="pointer-events-none absolute inset-0 -z-10 scale-[2.2] blur-3xl"
          aria-hidden="true"
          style="
            background:
              radial-gradient(circle at 35% 40%, var(--color-agua) 0%, color-mix(in srgb, var(--color-agua) 30%, transparent) 20%, transparent 48%),
              radial-gradient(circle at 70% 65%, var(--color-calor) 0%, color-mix(in srgb, var(--color-calor) 25%, transparent) 18%, transparent 45%);
            opacity: 0.55;
          "
        ></div>
        <div class="relative z-10">
          <PhoneMockup />
        </div>
      </div>
    </div>
  </div>
</section>
