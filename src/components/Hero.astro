---
import PhoneMockup from './PhoneMockup.astro';
---

<section id="inicio" class="relative isolate overflow-hidden">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 pt-12 pb-20 md:grid-cols-2 md:gap-8 md:px-10 md:pt-20 md:pb-28">
    <div class="flex flex-col gap-8">
      <p class="font-sans text-sm font-semibold tracking-[0.18em] uppercase text-(--color-agua)">
        Agua · Sombra · Respiramos
      </p>

      <h1 class="font-display text-6xl leading-[0.95] font-medium tracking-tight text-(--color-ink) sm:text-7xl md:text-[7.5rem]">
        València<br />Refresca
      </h1>

      <p class="font-display max-w-md text-2xl leading-tight text-(--color-ink) sm:text-3xl">
        <span class="text-(--color-calor) font-medium">1 de cada 4</span> manzanas de València está a más de 5 minutos del urinario público más cercano.
      </p>

      <p class="max-w-md text-base text-(--color-ink-soft)">
        Cartografía y cruces sobre 12 datasets públicos del Ajuntament.
        Pieza candidata a los <strong class="font-medium text-(--color-ink)">Premios Datos Abiertos València 2026</strong>.
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <a
          href="#mapa"
          class="inline-flex items-center gap-2 rounded-full bg-(--color-ink) px-6 py-3 text-sm font-medium text-white transition hover:bg-(--color-agua)"
        >
          Explora el mapa
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#faq"
          class="inline-flex items-center gap-2 rounded-full border border-(--color-ink) px-6 py-3 text-sm font-medium text-(--color-ink) transition hover:bg-(--color-ink) hover:text-white"
        >
          ¿Cómo se hizo?
        </a>
      </div>
    </div>

    <div class="flex justify-center md:justify-end">
      <PhoneMockup />
    </div>
  </div>
</section>
