---
import Logo from './Logo.astro';
import { t, type Lang, homeHref, mapaHref, participarHref, recientesHref } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const s = t(lang).nav;
const sw = t(lang).langSwitch;
const findingsLabel = lang === 'va' ? 'Troballes' : lang === 'en' ? 'Findings' : 'Hallazgos';
const participarLabel = lang === 'en' ? 'Get involved' : 'Participa';
const recientesLabel = lang === 'va' ? 'En directe' : lang === 'en' ? 'Latest' : 'En directo';
const homeUrl = homeHref(lang);
const mapaUrl = mapaHref(lang);
const participarUrl = participarHref(lang);
const recientesUrl = recientesHref(lang);
const langOptions: Array<{ code: Lang; short: string; label: string }> = [
  { code: 'es', short: sw.es, label: sw.labelEs },
  { code: 'va', short: sw.va, label: sw.labelVa },
  { code: 'en', short: sw.en, label: sw.labelEn },
];
const currentLang = langOptions.find((o) => o.code === lang)!;
---

<nav class="sticky top-0 z-50 w-full bg-(--color-bone)/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10">
    <a href={homeUrl} class="flex items-center gap-2.5 text-(--color-ink) transition hover:opacity-80">
      <Logo size={36} />
      <span class="font-display text-xl leading-none font-semibold">
        València<br /><span class="font-medium">Refresca</span>
      </span>
    </a>

    <ul class="hidden items-center gap-8 text-sm font-medium text-(--color-ink-soft) md:flex">
      <li><a href="#inicio" class="text-(--color-agua-deep) transition hover:text-(--color-ink)">{s.inicio}</a></li>
      <li><a href="#capas" class="transition hover:text-(--color-ink)">{s.capas}</a></li>
      <li><a href={mapaUrl} class="transition hover:text-(--color-ink)">{s.elMapa}</a></li>
      <li><a href={participarUrl} class="transition hover:text-(--color-ink)">{participarLabel}</a></li>
      <li><a href={recientesUrl} class="transition hover:text-(--color-ink)">{recientesLabel}</a></li>
      <li><a href="#hallazgos" class="transition hover:text-(--color-ink)">{findingsLabel}</a></li>
      <li><a href="#colabora" class="transition hover:text-(--color-ink)">{s.colabora}</a></li>
      <li><a href="#faq" class="transition hover:text-(--color-ink)">{s.faq}</a></li>
    </ul>

    <div class="flex items-center gap-2">
      <div class="relative hidden md:block" data-lang-menu>
        <button
          type="button"
          id="lang-menu-toggle"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label={sw.aria}
          class="inline-flex cursor-pointer items-center gap-1.5 rounded-full border border-(--color-ink)/15 px-3 py-1.5 text-xs font-semibold tracking-wider uppercase text-(--color-ink-soft) transition hover:border-(--color-ink) hover:text-(--color-ink)"
        >
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9" />
            <ellipse cx="12" cy="12" rx="4" ry="9" />
            <line x1="3" y1="12" x2="21" y2="12" />
          </svg>
          {currentLang.short}
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
        <ul
          id="lang-menu-panel"
          role="menu"
          hidden
          class="absolute top-full right-0 z-50 mt-2 w-44 overflow-hidden rounded-xl border border-(--color-ink)/10 bg-white py-1 shadow-lg"
        >
          {langOptions.map((opt) => (
            <li role="none">
              <a
                role="menuitem"
                href={homeHref(opt.code)}
                aria-current={opt.code === lang ? 'true' : undefined}
                class:list={[
                  'flex items-center justify-between gap-3 px-3 py-2 text-sm transition hover:bg-(--color-bone-soft)',
                  opt.code === lang ? 'font-semibold text-(--color-agua-deep)' : 'text-(--color-ink)',
                ]}
              >
                <span>{opt.label}</span>
                <span class="text-xs font-semibold tracking-wider uppercase text-(--color-ink-soft)">{opt.short}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <a
        href={mapaUrl}
        class="hidden md:inline-flex items-center rounded-full bg-(--color-agua-deep) px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-(--color-ink)"
      >
        {s.verMapa}
      </a>

      <button
        type="button"
        id="mobile-nav-toggle"
        aria-label={s.abrirMenu}
        aria-controls="mobile-nav"
        aria-expanded="false"
        data-label-open={s.abrirMenu}
        data-label-close={s.cerrarMenu}
        class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-(--color-ink) transition hover:bg-(--color-ink)/5 md:hidden"
      >
        <svg
          class="block h-5 w-5"
          data-icon="open"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
        <svg
          class="hidden h-5 w-5"
          data-icon="close"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-nav"
    hidden
    class="border-t border-(--color-ink)/8 bg-(--color-bone)/95 backdrop-blur md:hidden"
  >
    <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-6 py-4 text-base font-medium text-(--color-ink)">
      <li>
        <a href="#inicio" data-mobile-link class="block rounded-xl px-3 py-3 text-(--color-agua-deep) transition hover:bg-(--color-ink)/5">{s.inicio}</a>
      </li>
      <li>
        <a href="#capas" data-mobile-link class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{s.capas}</a>
      </li>
      <li>
        <a href={mapaUrl} class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{s.elMapa}</a>
      </li>
      <li>
        <a href={participarUrl} class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{participarLabel}</a>
      </li>
      <li>
        <a href={recientesUrl} class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{recientesLabel}</a>
      </li>
      <li>
        <a href="#colabora" data-mobile-link class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{s.colabora}</a>
      </li>
      <li>
        <a href="#faq" data-mobile-link class="block rounded-xl px-3 py-3 transition hover:bg-(--color-ink)/5">{s.faq}</a>
      </li>
      <li class="mt-2 border-t border-(--color-ink)/8 pt-3">
        <p class="px-3 pb-1 text-[11px] font-semibold tracking-wider uppercase text-(--color-ink-soft)">{sw.aria}</p>
        <div class="flex flex-wrap gap-2 px-3 pt-1">
          {langOptions.map((opt) => (
            <a
              href={homeHref(opt.code)}
              aria-current={opt.code === lang ? 'true' : undefined}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-xs font-semibold tracking-wider uppercase transition',
                opt.code === lang
                  ? 'border-(--color-agua-deep) bg-(--color-agua-soft) text-(--color-agua-deep)'
                  : 'border-(--color-ink)/15 text-(--color-ink-soft) hover:border-(--color-ink) hover:text-(--color-ink)',
              ]}
            >
              {opt.short}
            </a>
          ))}
        </div>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav');
  if (toggle && panel) {
    const openIcon = toggle.querySelector('[data-icon="open"]');
    const closeIcon = toggle.querySelector('[data-icon="close"]');
    const openLabel = toggle.dataset.labelOpen ?? 'Abrir menú';
    const closeLabel = toggle.dataset.labelClose ?? 'Cerrar menú';

    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
      panel.hidden = !open;
      openIcon?.classList.toggle('hidden', open);
      openIcon?.classList.toggle('block', !open);
      closeIcon?.classList.toggle('hidden', !open);
      closeIcon?.classList.toggle('block', open);
    };

    toggle.addEventListener('click', () => {
      setOpen(panel.hidden === true);
    });

    panel.querySelectorAll('a[data-mobile-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  }

  const langToggle = document.getElementById('lang-menu-toggle');
  const langPanel = document.getElementById('lang-menu-panel');
  const langWrap = document.querySelector('[data-lang-menu]');
  if (langToggle && langPanel && langWrap) {
    const setLangOpen = (open: boolean) => {
      langToggle.setAttribute('aria-expanded', String(open));
      (langPanel as HTMLElement).hidden = !open;
    };
    langToggle.addEventListener('click', (event) => {
      event.stopPropagation();
      setLangOpen((langPanel as HTMLElement).hidden === true);
    });
    document.addEventListener('click', (event) => {
      if (!langWrap.contains(event.target as Node)) setLangOpen(false);
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setLangOpen(false);
    });
  }
</script>
