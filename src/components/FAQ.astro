---
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const faq = t(lang).faq;
---

<section id="faq" class="mx-auto max-w-6xl px-6 py-16 md:px-10 md:py-20">
  <h2 class="text-center font-display text-3xl text-(--color-ink) md:text-4xl">{faq.heading}</h2>

  <div class="mt-10 grid gap-3 sm:grid-cols-2 sm:gap-x-6 sm:gap-y-3">
    {faq.questions.map((f) => (
      <details
        name="faq"
        class="group h-fit overflow-hidden rounded-xl bg-(--color-agua-soft)/40 ring-1 ring-(--color-ink)/8 transition open:bg-(--color-agua-soft)/70"
      >
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-(--color-ink) [&::-webkit-details-marker]:hidden">
          <span>{f.q}</span>
          <svg
            class="h-4 w-4 shrink-0 text-(--color-ink-soft) transition group-open:rotate-180"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M6 9l6 6 6-6" />
          </svg>
        </summary>
        <p class="px-5 pb-4 text-sm leading-relaxed text-(--color-ink-soft)" set:html={f.a}></p>
      </details>
    ))}
  </div>
</section>
