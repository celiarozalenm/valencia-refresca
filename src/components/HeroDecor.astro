---
// Decoración detrás del móvil del hero: gotas y soles del logo
// con tamaños / rotaciones / opacidades variados.
// Valores hardcoded para que el render sea estable entre SSR e hidratación.

type Item = {
  kind: 'drop' | 'sun';
  // posición en % relativo al contenedor
  top: number;
  left: number;
  // tamaño en px
  size: number;
  rotate: number; // grados
  opacity: number; // 0..1
};

// Iconos invadiendo el espacio del móvil: lados a left 8-12% (izq) y 38-44% (dcha),
// arriba/abajo solapando el chasis. El móvil va al z-10, los iconos quedan detrás.
const items: Item[] = [
  // Arriba (asomando por detrás del notch / status bar)
  { kind: 'sun', top: 4, left: 12, size: 130, rotate: -12, opacity: 0.6 },
  { kind: 'drop', top: 6, left: 42, size: 100, rotate: 18, opacity: 0.6 },
  { kind: 'sun', top: 18, left: 28, size: 56, rotate: 25, opacity: 0.45 },
  // Lado izquierdo (overlap con borde del móvil)
  { kind: 'drop', top: 26, left: 8, size: 130, rotate: -22, opacity: 0.6 },
  { kind: 'sun', top: 52, left: 6, size: 110, rotate: 18, opacity: 0.55 },
  { kind: 'drop', top: 78, left: 8, size: 95, rotate: -10, opacity: 0.55 },
  // Lado derecho (overlap con borde del móvil)
  { kind: 'sun', top: 30, left: 40, size: 100, rotate: -18, opacity: 0.55 },
  { kind: 'drop', top: 56, left: 42, size: 120, rotate: 14, opacity: 0.55 },
  { kind: 'sun', top: 82, left: 40, size: 100, rotate: 22, opacity: 0.55 },
  // Abajo (asomando por debajo del home indicator)
  { kind: 'drop', top: 100, left: 16, size: 100, rotate: 12, opacity: 0.55 },
  { kind: 'sun', top: 102, left: 28, size: 80, rotate: -20, opacity: 0.5 },
  { kind: 'drop', top: 100, left: 42, size: 90, rotate: 20, opacity: 0.55 },
  // Pequeño extra
  { kind: 'sun', top: 90, left: 24, size: 38, rotate: 30, opacity: 0.4 },
];
---

<div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
  {items.map((it) => (
    <div
      class="absolute"
      style={`
        top: ${it.top}%;
        left: ${it.left}%;
        width: ${it.size}px;
        height: ${it.size}px;
        transform: translate(-50%, -50%) rotate(${it.rotate}deg);
        opacity: ${it.opacity};
      `}
    >
      {it.kind === 'drop' ? (
        <svg viewBox="0 0 80 80" class="h-full w-full">
          <path
            d="M30 12 C 38 26, 48 38, 48 50 C 48 60, 40 67, 30 67 C 20 67, 12 60, 12 50 C 12 38, 22 26, 30 12 Z"
            fill="#3b82f6"
          />
        </svg>
      ) : (
        <svg viewBox="0 0 80 80" class="h-full w-full">
          <g transform="translate(40 40)" fill="#f97316">
            <circle cx="0" cy="0" r="14" />
            <rect x="-1.5" y="-24" width="3" height="6" rx="1.5" />
            <rect x="-1.5" y="18" width="3" height="6" rx="1.5" />
            <rect x="18" y="-1.5" width="6" height="3" rx="1.5" />
            <rect x="-24" y="-1.5" width="6" height="3" rx="1.5" />
            <rect x="-1.5" y="-24" width="3" height="6" rx="1.5" transform="rotate(45)" />
            <rect x="-1.5" y="-24" width="3" height="6" rx="1.5" transform="rotate(135)" />
            <rect x="-1.5" y="-24" width="3" height="6" rx="1.5" transform="rotate(-45)" />
            <rect x="-1.5" y="-24" width="3" height="6" rx="1.5" transform="rotate(-135)" />
          </g>
        </svg>
      )}
    </div>
  ))}
</div>
