---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Banner from '../components/Banner.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CollaborateBox from '../components/CollaborateBox.astro';
import FAQ from '../components/FAQ.astro';
import Map from '../components/Map.tsx';
---

<Base>
  <Hero />
  <Features />
  <Banner />
  <HowItWorks />
  <CollaborateBox />
  <FAQ />

  <section id="mapa" class="border-t border-(--color-ink)/8">
    <div class="mx-auto max-w-7xl px-6 py-20 md:px-10">
      <div class="mb-10 max-w-3xl">
        <p class="font-sans text-sm font-medium tracking-[0.18em] uppercase text-(--color-agua)">El mapa real</p>
        <h2 class="mt-3 font-display text-3xl leading-tight text-(--color-ink) md:text-5xl">
          Sobreponlas y verás dónde València se cuida — y dónde no.
        </h2>
        <p class="mt-4 max-w-2xl text-(--color-ink-soft) md:text-lg">
          Los puntos naranjas son los 230 urinarios. Los azules, las 832 fuentes. El tinte de los barrios es la
          vulnerabilidad demográfica del padrón 2021.
        </p>
      </div>

      <Map client:only="react" />
    </div>
  </section>
</Base>
