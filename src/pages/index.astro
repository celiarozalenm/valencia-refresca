---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base>
  <Hero />

  <section id="mapa" class="mx-auto max-w-6xl px-6 py-24 md:px-10">
    <h2 class="font-display text-3xl text-(--color-ink) md:text-4xl">El mapa llegará aquí</h2>
    <p class="mt-4 max-w-2xl text-(--color-ink-soft)">
      Próximo paso: integrar MapLibre GL con las capas de fuentes, urinarios, sombra y vulnerabilidad por barrios.
    </p>
  </section>

  <section id="metodologia" class="mx-auto max-w-6xl px-6 py-24 md:px-10">
    <h2 class="font-display text-3xl text-(--color-ink) md:text-4xl">¿Cómo se hizo?</h2>
    <p class="mt-4 max-w-2xl text-(--color-ink-soft)">
      Datos del Portal de Datos Abiertos del Ajuntament de València. Análisis con Python + geopandas. Código abierto.
    </p>
  </section>
</Base>
